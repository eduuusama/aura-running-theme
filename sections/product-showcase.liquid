{%- comment -%}
  Product Showcase — Split layout (image left, info right) + ingredients section
  Used on homepage to feature a single product
{%- endcomment -%}

{%- assign featured_product = section.settings.product -%}

<section id="products" class="scroll-mt-16">
  {%- comment -%} === SPLIT LAYOUT: Image + Product Info === {%- endcomment -%}
  <div class="grid md:grid-cols-2 md:h-[calc(100vh-64px)]">

    {%- comment -%} Left — Product Image {%- endcomment -%}
    <div class="aspect-[4/3] md:aspect-auto bg-[#f5f5f3] relative overflow-hidden">
      {%- if section.settings.product_image -%}
        <img
          src="{{ section.settings.product_image | image_url: width: 1200 }}"
          alt="{{ featured_product.title | default: 'Product' }}"
          class="w-full h-full object-cover"
          loading="lazy"
        >
      {%- elsif featured_product.featured_image -%}
        <img
          src="{{ featured_product.featured_image | image_url: width: 1200 }}"
          alt="{{ featured_product.title }}"
          class="w-full h-full object-cover"
          loading="lazy"
        >
      {%- endif -%}
    </div>

    {%- comment -%} Right — Product Info + Accordions {%- endcomment -%}
    <div class="md:h-full overflow-y-auto">
      <div class="px-8 py-6 md:px-12 lg:px-20 md:pt-12 md:pb-8 w-full">
        <p class="text-[10px] uppercase tracking-[0.2em] text-muted-foreground mb-4">
          {{ section.settings.ref_label | default: 'Ref — 001' }}
        </p>
        <h2 class="text-3xl md:text-4xl font-light tracking-tight mb-2">
          {%- if featured_product -%}
            {{ featured_product.title }}
          {%- else -%}
            {{ section.settings.product_title | default: 'Aura Stride' }}
          {%- endif -%}
        </h2>
        <p class="text-lg text-muted-foreground font-light mb-4">
          {{ section.settings.product_tagline | default: 'For everyday use' }}
        </p>
        <p class="text-xl font-light mb-8">
          {%- if featured_product -%}
            {{ featured_product.price | money }}
          {%- else -%}
            {{ section.settings.price | default: '$48.00' }}
          {%- endif -%}
        </p>

        {%- comment -%} Accordion — Description {%- endcomment -%}
        <div class="accordion-group">
          <div class="accordion-item is-open border-t border-border">
            <button class="accordion-trigger w-full flex items-center justify-between py-5 text-left">
              <span class="text-sm font-medium tracking-wide">{{ 'product.description' | t }}</span>
              <span class="accordion-icon text-lg text-muted-foreground">+</span>
            </button>
            <div class="accordion-content">
              <div class="pb-5 text-sm text-muted-foreground font-light leading-relaxed">
                {%- if featured_product -%}
                  {{ featured_product.description }}
                {%- else -%}
                  {{ section.settings.description | default: 'Premium anti-chafe balm engineered for daily training runs and race day performance.' }}
                {%- endif -%}
              </div>
            </div>
          </div>

          <div class="accordion-item border-t border-border">
            <button class="accordion-trigger w-full flex items-center justify-between py-5 text-left">
              <span class="text-sm font-medium tracking-wide">{{ 'product.how_to_apply' | t }}</span>
              <span class="accordion-icon text-lg text-muted-foreground">+</span>
            </button>
            <div class="accordion-content">
              <div class="pb-5 text-sm text-muted-foreground font-light leading-relaxed">
                {{ section.settings.how_to_apply | default: 'Apply generously to friction-prone areas before your run. Reapply every 4-6 hours during extended efforts.' }}
              </div>
            </div>
          </div>

          <div class="accordion-item border-t border-border">
            <button class="accordion-trigger w-full flex items-center justify-between py-5 text-left">
              <span class="text-sm font-medium tracking-wide">{{ 'product.ingredients' | t }}</span>
              <span class="accordion-icon text-lg text-muted-foreground">+</span>
            </button>
            <div class="accordion-content">
              <div class="pb-5 text-sm text-muted-foreground font-light leading-relaxed">
                {{ section.settings.ingredients_list | default: 'Coconut Oil, Beeswax, Cocoa Butter, Vitamin E, Zinc Oxide, Shea Butter' }}
              </div>
            </div>
          </div>
        </div>

        <div class="border-b border-border"></div>

        {%- comment -%} CTA Buttons {%- endcomment -%}
        <div class="flex flex-col md:flex-row gap-3 mt-8">
          {%- if featured_product -%}
            <button
              class="flex-1 h-14 bg-foreground text-background flex items-center justify-center text-xs font-medium uppercase tracking-[0.15em] hover:bg-foreground/90 transition-colors"
              onclick="document.dispatchEvent(new CustomEvent('cart:add', { detail: { id: {{ featured_product.selected_or_first_available_variant.id }} } }))"
            >
              {{ 'general.add_to_cart' | t }}
            </button>
          {%- else -%}
            <a href="/collections/all" class="flex-1 h-14 bg-foreground text-background flex items-center justify-center text-xs font-medium uppercase tracking-[0.15em] hover:bg-foreground/90 transition-colors">
              {{ 'general.add_to_cart' | t }}
            </a>
          {%- endif -%}
          <a
            href="{{ featured_product.url | default: section.settings.discover_link | default: '/collections/all' }}"
            class="flex-1 h-14 border border-foreground flex items-center justify-center text-xs font-medium uppercase tracking-[0.15em] hover:bg-foreground hover:text-background transition-colors"
          >
            {{ 'general.discover' | t }}
          </a>
        </div>
      </div>
    </div>
  </div>

  {%- comment -%} === INGREDIENTS SECTION === {%- endcomment -%}
  {%- if section.blocks.size > 0 -%}
    <div class="relative md:min-h-[80vh] bg-[#3d3530]" data-ingredient-section>

      {%- comment -%} Background images (crossfade on hover) {%- endcomment -%}
      {%- for block in section.blocks -%}
        {%- if block.settings.image -%}
          <div class="ingredient-bg {% if forloop.first %}is-active{% endif %}" data-ingredient-bg="{{ forloop.index0 }}">
            <img
              src="{{ block.settings.image | image_url: width: 1600 }}"
              alt="{{ block.settings.name }}"
              class="w-full h-full object-cover"
              loading="lazy"
            >
          </div>
        {%- endif -%}
      {%- endfor -%}
      <div class="absolute inset-0 bg-black/40"></div>

      {%- comment -%} Desktop Layout {%- endcomment -%}
      <div class="hidden md:block relative z-10 min-h-[80vh]">
        <div class="absolute top-12 left-12 right-12">
          <p class="text-[10px] uppercase tracking-[0.3em] text-white/80 font-light mb-4">
            {{ 'product.key_ingredients' | t }}
          </p>
          <div class="border-t border-white/30"></div>
        </div>

        <div class="absolute top-32 left-12 space-y-4">
          {%- for block in section.blocks -%}
            <div
              data-ingredient-trigger="{{ forloop.index0 }}"
              class="flex items-baseline gap-5 cursor-pointer transition-opacity duration-300"
              {{ block.shopify_attributes }}
            >
              <span class="text-white/60 text-sm font-light">0{{ forloop.index }}</span>
              <span class="text-white text-[36px] font-light">{{ block.settings.name }}</span>
              <span class="text-[10px] uppercase tracking-[0.15em] text-white/70 font-light">{{ block.settings.benefit }}</span>
            </div>
          {%- endfor -%}
        </div>

        <div class="absolute bottom-12 right-12 max-w-md text-right">
          <p class="text-white/90 text-lg font-light leading-relaxed">
            {{ section.settings.ingredients_description | default: 'Each ingredient is selected for its proven ability to create a lasting moisture barrier while nourishing the skin through hours of repetitive movement.' }}
          </p>
        </div>
      </div>

      {%- comment -%} Mobile Layout — Accordion {%- endcomment -%}
      <div class="md:hidden relative z-10 px-6 py-12">
        <p class="text-[10px] uppercase tracking-[0.3em] text-white/80 font-light mb-3">
          {{ 'product.key_ingredients' | t }}
        </p>
        <p class="text-white/90 text-base font-light mb-10">
          {{ section.settings.ingredients_description | default: 'Each ingredient is selected for its proven ability to create a lasting moisture barrier.' }}
        </p>

        <div class="accordion-group">
          {%- for block in section.blocks -%}
            <div class="accordion-item border-t border-white/30" {{ block.shopify_attributes }}>
              <button class="accordion-trigger w-full py-5 flex items-center justify-between">
                <div class="flex items-baseline gap-3">
                  <span class="text-white/60 text-sm font-light">0{{ forloop.index }}</span>
                  <span class="text-white text-xl font-light">{{ block.settings.name }}</span>
                  <span class="text-[9px] uppercase tracking-[0.1em] text-white/70 font-light">{{ block.settings.benefit }}</span>
                </div>
                <span class="accordion-icon text-white/70 text-lg">+</span>
              </button>
              <div class="accordion-content">
                <p class="text-white/80 text-sm font-light pb-4">{{ block.settings.description }}</p>
              </div>
            </div>
          {%- endfor -%}
        </div>
      </div>
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Product Showcase",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Featured Product"
    },
    {
      "type": "image_picker",
      "id": "product_image",
      "label": "Product Image (override)"
    },
    {
      "type": "text",
      "id": "ref_label",
      "label": "Reference Label",
      "default": "Ref — 001"
    },
    {
      "type": "text",
      "id": "product_title",
      "label": "Product Title (fallback)",
      "default": "Aura Stride"
    },
    {
      "type": "text",
      "id": "product_tagline",
      "label": "Tagline",
      "default": "For everyday use"
    },
    {
      "type": "text",
      "id": "price",
      "label": "Price (fallback)",
      "default": "$39.00"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description (fallback)"
    },
    {
      "type": "text",
      "id": "how_to_apply",
      "label": "How to Apply",
      "default": "Apply generously to friction-prone areas before your run. Reapply every 4-6 hours during extended efforts."
    },
    {
      "type": "text",
      "id": "ingredients_list",
      "label": "Ingredients List",
      "default": "Coconut Oil, Beeswax, Cocoa Butter, Vitamin E, Zinc Oxide, Shea Butter"
    },
    {
      "type": "url",
      "id": "discover_link",
      "label": "Discover Link"
    },
    {
      "type": "textarea",
      "id": "ingredients_description",
      "label": "Ingredients Section Description",
      "default": "Each ingredient is selected for its proven ability to create a lasting moisture barrier while nourishing the skin through hours of repetitive movement."
    }
  ],
  "blocks": [
    {
      "type": "ingredient",
      "name": "Ingredient",
      "settings": [
        {
          "type": "text",
          "id": "name",
          "label": "Name",
          "default": "Coconut Oil"
        },
        {
          "type": "text",
          "id": "benefit",
          "label": "Benefit Tag",
          "default": "Moisture barrier"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Creates a breathable moisture barrier that protects skin during extended activity."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Background Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Showcase",
      "blocks": [
        { "type": "ingredient", "settings": { "name": "Coconut Oil", "benefit": "Moisture barrier" } },
        { "type": "ingredient", "settings": { "name": "Beeswax", "benefit": "Friction shield" } },
        { "type": "ingredient", "settings": { "name": "Vitamin E", "benefit": "Skin repair" } }
      ]
    }
  ]
}
{% endschema %}
