{%- comment -%}
  Product Hero — 50/50 split layout matching React original
  Left: edge-to-edge product image with thumbnail gallery
  Right: Product info, subscribe selector, accordions, cross-sell
{%- endcomment -%}

{%- comment -%} Mobile Layout {%- endcomment -%}
<div class="lg:hidden">
  {%- comment -%} Image Gallery - Mobile {%- endcomment -%}
  <div class="relative bg-secondary/20">
    <div class="aspect-square">
      <img
        src="{{ product.featured_image | image_url: width: 1200 }}"
        alt="{{ product.featured_image.alt | default: product.title }}"
        class="w-full h-full object-cover"
        id="product-main-image-mobile"
        loading="eager"
      >
    </div>
    {%- if product.images.size > 1 -%}
      <div class="absolute bottom-0 left-0 right-0 flex justify-center gap-2 py-3 px-4 bg-gradient-to-t from-background/40 to-transparent">
        {%- for image in product.images -%}
          <button
            class="w-10 h-10 border overflow-hidden bg-background transition-colors {% if forloop.first %}border-foreground{% else %}border-transparent hover:border-foreground/50{% endif %}"
            onclick="document.getElementById('product-main-image-mobile').src='{{ image | image_url: width: 1200 }}'; this.parentElement.querySelectorAll('button').forEach(b => { b.classList.remove('border-foreground'); b.classList.add('border-transparent'); }); this.classList.remove('border-transparent'); this.classList.add('border-foreground');"
          >
            <img src="{{ image | image_url: width: 100 }}" alt="{{ image.alt | default: product.title }}" class="w-full h-full object-cover" loading="lazy">
          </button>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>

  {%- comment -%} Product Info - Mobile {%- endcomment -%}
  <div class="px-6 md:px-12 py-8 md:py-12 md:max-w-2xl md:mx-auto">
    <p class="text-[10px] uppercase tracking-[0.2em] text-muted-foreground mb-4 font-medium">
      {{ section.settings.ref_label | default: 'REF — 001' }}
    </p>
    <h1 class="font-light text-[28px] md:text-[36px] tracking-[-0.01em] leading-[1.2] mb-1">
      {{ product.title }}
    </h1>
    <p class="text-lg md:text-xl font-light text-muted-foreground mb-3">
      {{ section.settings.subtitle }}
    </p>
    <p class="text-xl md:text-2xl font-light tracking-[-0.01em] mb-3">
      {{ product.selected_or_first_available_variant.price | money }}
    </p>

    {%- comment -%} Subscribe & Save Selector - Mobile {%- endcomment -%}
    <div class="space-y-3 mb-8" data-purchase-selector>
      <button
        class="purchase-option w-full p-4 border border-foreground text-left transition-all duration-300 is-selected"
        data-type="subscribe"
        onclick="window.ProductForm.selectPurchaseType(this)"
      >
        <div class="flex items-center gap-2 flex-wrap mb-2">
          <div class="radio-dot w-4 h-4 rounded-full border-2 border-foreground flex items-center justify-center transition-colors">
            <div class="w-2 h-2 rounded-full bg-foreground"></div>
          </div>
          <span class="text-sm font-light">Subscribe &</span>
          <span class="text-[9px] uppercase tracking-[0.1em] font-bold bg-foreground text-background px-1.5 py-0.5">Save 20%</span>
          <span class="text-sm font-light text-muted-foreground">+ Free Shipping</span>
        </div>
        <div class="flex items-center gap-2 pl-6">
          <span class="text-sm line-through text-muted-foreground">{{ product.selected_or_first_available_variant.price | money }}</span>
          <span class="text-sm font-medium" data-discounted-price>
            {%- assign price_cents = product.selected_or_first_available_variant.price -%}
            {%- assign discounted = price_cents | times: 80 | divided_by: 100 -%}
            {{ discounted | money }}
          </span>
        </div>
      </button>

      <button
        class="purchase-option w-full p-4 border border-border text-left transition-all duration-300"
        data-type="onetime"
        onclick="window.ProductForm.selectPurchaseType(this)"
      >
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-2">
            <div class="radio-dot w-4 h-4 rounded-full border-2 border-muted-foreground flex items-center justify-center transition-colors"></div>
            <span class="text-sm font-light">One-time purchase</span>
          </div>
          <span class="text-sm font-medium">{{ product.selected_or_first_available_variant.price | money }}</span>
        </div>
      </button>
    </div>

    {%- comment -%} Sticky Add to Cart - Mobile {%- endcomment -%}
    <div class="fixed bottom-0 left-0 right-0 bg-background border-t border-border p-4 z-40 lg:hidden">
      <button
        id="add-to-cart-btn-mobile"
        class="w-full bg-foreground text-background text-sm font-medium h-14 hover:bg-foreground/90 transition-all duration-300 disabled:opacity-50 disabled:cursor-not-allowed"
        {% unless product.available %}disabled{% endunless %}
        onclick="window.ProductForm.addToCart()"
      >
        {%- if product.available -%}
          Add to cart
        {%- else -%}
          {{ 'general.sold_out' | t }}
        {%- endif -%}
      </button>
    </div>

    {%- comment -%} Product Accordions - Mobile {%- endcomment -%}
    <div class="pb-32">
      <div class="accordion-group">
        <div class="accordion-item is-open border-t border-border">
          <button class="accordion-trigger w-full py-6 flex items-center justify-between text-base font-light hover:opacity-70 transition-opacity">
            Description
            <span class="accordion-icon text-base">+</span>
          </button>
          <div class="accordion-content">
            <div class="pb-8 space-y-6 text-base text-muted-foreground font-light leading-[1.6]">
              {{ section.settings.description }}
            </div>
          </div>
        </div>

        <div class="accordion-item border-t border-border">
          <button class="accordion-trigger w-full py-6 flex items-center justify-between text-base font-light hover:opacity-70 transition-opacity">
            How to Apply
            <span class="accordion-icon text-base">+</span>
          </button>
          <div class="accordion-content">
            <div class="pb-8 text-base text-muted-foreground font-light leading-[1.6]">
              {{ section.settings.how_to_apply }}
            </div>
          </div>
        </div>

        <div class="accordion-item border-t border-border">
          <button class="accordion-trigger w-full py-6 flex items-center justify-between text-base font-light hover:opacity-70 transition-opacity">
            Ingredients
            <span class="accordion-icon text-base">+</span>
          </button>
          <div class="accordion-content">
            <div class="pb-8 text-base text-muted-foreground font-light leading-[1.6]">
              {{ section.settings.ingredients_list }}
            </div>
          </div>
        </div>

        <div class="accordion-item border-t border-b border-border">
          <button class="accordion-trigger w-full py-6 flex items-center justify-between text-base font-light hover:opacity-70 transition-opacity">
            Shipping
            <span class="accordion-icon text-base">+</span>
          </button>
          <div class="accordion-content">
            <div class="pb-8 text-base text-muted-foreground font-light leading-[1.6]">
              {{ section.settings.shipping_info | default: 'Free shipping on orders over $50. Standard shipping: 3-5 business days.' }}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

{%- comment -%} Desktop Layout — 50/50 Split {%- endcomment -%}
<div class="hidden lg:block">
  <div class="min-h-[calc(100vh-64px)] grid grid-cols-2">
    {%- comment -%} Left — Edge-to-edge sticky image {%- endcomment -%}
    <div class="bg-secondary/20 relative">
      <div class="sticky top-16 h-[calc(100vh-64px)] flex flex-col">
        <div class="flex-1 overflow-hidden">
          <img
            src="{{ product.featured_image | image_url: width: 1400 }}"
            alt="{{ product.featured_image.alt | default: product.title }}"
            class="w-full h-full object-cover"
            id="product-main-image"
            loading="eager"
          >
        </div>
        {%- if product.images.size > 1 -%}
          <div class="absolute bottom-0 left-0 right-0 flex justify-center gap-4 py-6 bg-gradient-to-t from-background/60 to-transparent">
            {%- for image in product.images -%}
              <button
                class="w-16 h-16 border overflow-hidden bg-background transition-colors {% if forloop.first %}border-foreground{% else %}border-transparent hover:border-foreground/50{% endif %}"
                onclick="document.getElementById('product-main-image').src='{{ image | image_url: width: 1400 }}'; this.parentElement.querySelectorAll('button').forEach(b => { b.classList.remove('border-foreground'); b.classList.add('border-transparent'); }); this.classList.remove('border-transparent'); this.classList.add('border-foreground');"
              >
                <img src="{{ image | image_url: width: 200 }}" alt="{{ image.alt | default: product.title }}" class="w-full h-full object-cover" loading="lazy">
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
    </div>

    {%- comment -%} Right — Product Info (scrollable) {%- endcomment -%}
    <div class="px-16 lg:px-24 xl:px-32 py-24">
      <div class="max-w-lg">
        <p class="text-[10px] uppercase tracking-[0.2em] text-muted-foreground mb-12 font-medium">
          {{ section.settings.ref_label | default: 'REF — 001' }}
        </p>

        <h1 class="font-light text-[36px] lg:text-[42px] tracking-[-0.02em] leading-[1.1] mb-2">
          {{ product.title }}
        </h1>
        <p class="text-xl lg:text-2xl font-light text-muted-foreground mb-6">
          {{ section.settings.subtitle }}
        </p>

        <p class="text-2xl font-light tracking-[-0.01em] mb-4" id="product-price">
          {{ product.selected_or_first_available_variant.price | money }}
        </p>

        {%- comment -%} Subscribe & Save Selector {%- endcomment -%}
        <div class="space-y-3 mb-8" data-purchase-selector>
          <button
            class="purchase-option w-full h-14 px-4 border border-foreground text-left transition-all duration-300 is-selected"
            data-type="subscribe"
            onclick="window.ProductForm.selectPurchaseType(this)"
          >
            <div class="flex items-center justify-between gap-4 h-full">
              <div class="flex items-center gap-2 flex-shrink-0">
                <div class="radio-dot w-4 h-4 rounded-full border-2 border-foreground flex items-center justify-center transition-colors">
                  <div class="w-2 h-2 rounded-full bg-foreground"></div>
                </div>
                <span class="text-sm font-light whitespace-nowrap">Subscribe &</span>
                <span class="text-[9px] uppercase tracking-[0.1em] font-bold bg-foreground text-background px-1.5 py-0.5">Save 20%</span>
                <span class="text-sm font-light text-muted-foreground whitespace-nowrap">+ Free Shipping</span>
              </div>
              <div class="flex items-center gap-2 flex-shrink-0">
                <span class="text-sm line-through text-muted-foreground">{{ product.selected_or_first_available_variant.price | money }}</span>
                <span class="text-sm font-medium" data-discounted-price>
                  {%- assign price_cents = product.selected_or_first_available_variant.price -%}
                  {%- assign discounted = price_cents | times: 80 | divided_by: 100 -%}
                  {{ discounted | money }}
                </span>
              </div>
            </div>
          </button>

          <button
            class="purchase-option w-full h-14 px-4 border border-border text-left transition-all duration-300"
            data-type="onetime"
            onclick="window.ProductForm.selectPurchaseType(this)"
          >
            <div class="flex items-center justify-between h-full">
              <div class="flex items-center gap-3">
                <div class="radio-dot w-4 h-4 rounded-full border-2 border-muted-foreground flex items-center justify-center transition-colors"></div>
                <span class="text-sm font-light">One-time purchase</span>
              </div>
              <span class="text-sm font-medium">{{ product.selected_or_first_available_variant.price | money }}</span>
            </div>
          </button>
        </div>

        {%- comment -%} Quantity + Add to Cart {%- endcomment -%}
        <div class="flex items-center gap-4 mb-16">
          <div class="flex items-center border border-foreground/30 h-14">
            <button onclick="window.ProductForm.updateQty(-1)" class="w-12 h-full flex items-center justify-center hover:bg-muted transition-colors">
              {% render 'icon-minus' %}
            </button>
            <input
              type="number"
              id="product-quantity"
              value="1"
              min="1"
              class="w-12 h-full text-center text-sm border-x border-foreground/30 bg-transparent outline-none"
            >
            <button onclick="window.ProductForm.updateQty(1)" class="w-12 h-full flex items-center justify-center hover:bg-muted transition-colors">
              {% render 'icon-plus' %}
            </button>
          </div>

          <button
            id="add-to-cart-btn"
            class="flex-1 h-14 bg-foreground text-background flex items-center justify-center text-sm font-medium hover:bg-foreground/90 transition-all duration-300 disabled:opacity-50 disabled:cursor-not-allowed"
            {% unless product.available %}disabled{% endunless %}
            onclick="window.ProductForm.addToCart()"
          >
            {%- if product.available -%}
              Add to cart
            {%- else -%}
              {{ 'general.sold_out' | t }}
            {%- endif -%}
          </button>
        </div>

        {%- comment -%} Product Accordions {%- endcomment -%}
        <div class="accordion-group">
          <div class="accordion-item is-open border-t border-border">
            <button class="accordion-trigger w-full py-6 flex items-center justify-between text-base font-light hover:opacity-70 transition-opacity">
              Description
              <span class="accordion-icon text-base">+</span>
            </button>
            <div class="accordion-content">
              <div class="pb-8 space-y-6 text-base text-muted-foreground font-light leading-[1.6]">
                {{ section.settings.description }}
              </div>
            </div>
          </div>

          <div class="accordion-item border-t border-border">
            <button class="accordion-trigger w-full py-6 flex items-center justify-between text-base font-light hover:opacity-70 transition-opacity">
              How to Apply
              <span class="accordion-icon text-base">+</span>
            </button>
            <div class="accordion-content">
              <div class="pb-8 text-base text-muted-foreground font-light leading-[1.6]">
                {{ section.settings.how_to_apply }}
              </div>
            </div>
          </div>

          <div class="accordion-item border-t border-border">
            <button class="accordion-trigger w-full py-6 flex items-center justify-between text-base font-light hover:opacity-70 transition-opacity">
              Ingredients
              <span class="accordion-icon text-base">+</span>
            </button>
            <div class="accordion-content">
              <div class="pb-8 text-base text-muted-foreground font-light leading-[1.6]">
                {{ section.settings.ingredients_list }}
              </div>
            </div>
          </div>

          <div class="accordion-item border-t border-b border-border">
            <button class="accordion-trigger w-full py-6 flex items-center justify-between text-base font-light hover:opacity-70 transition-opacity">
              Shipping
              <span class="accordion-icon text-base">+</span>
            </button>
            <div class="accordion-content">
              <div class="pb-8 text-base text-muted-foreground font-light leading-[1.6]">
                {{ section.settings.shipping_info | default: 'Free shipping on orders over $50. Standard shipping: 3-5 business days.' }}
              </div>
            </div>
          </div>
        </div>

        {%- comment -%} Cross-sell {%- endcomment -%}
        {%- if section.settings.cross_sell_text != blank -%}
          <div class="mt-8">
            <p class="text-sm text-muted-foreground font-light leading-relaxed">
              {{ section.settings.cross_sell_text }}
            </p>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

{%- comment -%} Product Form JS Data {%- endcomment -%}
<script type="application/json" id="product-variants-json">
  {{ product.variants | json }}
</script>

<script src="{{ 'product-form.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Product Hero",
  "tag": "div",
  "settings": [
    { "type": "text", "id": "ref_label", "label": "REF Label", "default": "REF — 001" },
    { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "For Every Run" },
    { "type": "richtext", "id": "description", "label": "Description" },
    { "type": "textarea", "id": "how_to_apply", "label": "How to Apply" },
    { "type": "textarea", "id": "ingredients_list", "label": "Ingredients List" },
    { "type": "textarea", "id": "shipping_info", "label": "Shipping Info", "default": "Free shipping on orders over $50. Standard shipping: 3-5 business days." },
    { "type": "textarea", "id": "cross_sell_text", "label": "Cross-sell Text" }
  ]
}
{% endschema %}
