{%- comment -%}
  Related Products — 3-column grid of product cards
  Uses collection picker or falls back to products in same collection
{%- endcomment -%}

{%- if section.settings.collection != blank -%}
  {%- assign source_collection = collections[section.settings.collection] -%}
{%- else -%}
  {%- assign source_collection = product.collections.first -%}
{%- endif -%}

{%- assign related = '' | split: '' -%}
{%- for p in source_collection.products limit: 4 -%}
  {%- if p.id != product.id -%}
    {%- assign related = related | push: p -%}
  {%- endif -%}
{%- endfor -%}

{%- if related.size > 0 -%}
<section class="py-20 md:py-28 bg-background">
  <div class="container">
    <p class="text-xs tracking-[0.2em] uppercase text-muted-foreground mb-12 font-light">
      {{ section.settings.heading | default: 'Related Products' }}
    </p>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-12">
      {%- for p in related limit: 3 -%}
        <a href="{{ p.url }}" class="group block">
          <div class="aspect-square overflow-hidden bg-[hsl(var(--secondary)/0.2)] mb-6">
            {%- if p.featured_image -%}
              <img
                src="{{ p.featured_image | image_url: width: 800 }}"
                alt="{{ p.featured_image.alt | default: p.title }}"
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                loading="lazy"
              >
            {%- endif -%}
          </div>
          <h3 class="text-base font-light mb-2 group-hover:opacity-60 transition-opacity">
            {{ p.title }}
          </h3>
          <p class="text-sm text-muted-foreground">
            {{ p.price | money }}
          </p>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>
{%- endif -%}

{% schema %}
{
  "name": "Related Products",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Related Products" },
    { "type": "collection", "id": "collection", "label": "Collection", "info": "Optional. Falls back to the product's first collection." }
  ],
  "presets": [{ "name": "Related Products" }]
}
{% endschema %}
