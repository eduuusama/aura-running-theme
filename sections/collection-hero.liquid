{%- comment -%}
  Collection Hero — Hero banner for shop/collection pages
{%- endcomment -%}

<section class="relative h-[60vh] min-h-[400px] overflow-hidden flex items-end">
  {%- if section.settings.image -%}
    <img src="{{ section.settings.image | image_url: width: 2000 }}" alt="{{ collection.title }}" class="absolute inset-0 w-full h-full object-cover" loading="eager">
  {%- elsif collection.image -%}
    <img src="{{ collection.image | image_url: width: 2000 }}" alt="{{ collection.title }}" class="absolute inset-0 w-full h-full object-cover" loading="eager">
  {%- else -%}
    <div class="absolute inset-0 bg-muted"></div>
  {%- endif -%}
  <div class="absolute inset-0 bg-black/30"></div>
  <div class="relative z-10 container pb-12 md:pb-16">
    <h1 class="font-serif italic text-4xl md:text-6xl text-white font-light tracking-tight animate-fade-in">
      {{ section.settings.heading | default: collection.title | default: 'Shop' }}
    </h1>
    {%- if section.settings.subtitle != blank -%}
      <p class="text-white/70 text-sm md:text-base font-light mt-4 max-w-lg animate-fade-in" style="animation-delay: 0.2s;">
        {{ section.settings.subtitle }}
      </p>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Collection Hero",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Background Image" },
    { "type": "text", "id": "heading", "label": "Heading" },
    { "type": "text", "id": "subtitle", "label": "Subtitle" }
  ]
}
{% endschema %}
