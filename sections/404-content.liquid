{%- comment -%}
  404 Page — Not Found
{%- endcomment -%}

<section class="py-24 md:py-32 text-center">
  <div class="container max-w-lg mx-auto">
    <p class="text-xs tracking-[0.2em] uppercase text-muted-foreground mb-6 font-light">404</p>
    <h1 class="text-3xl md:text-4xl font-light tracking-tight mb-4">{{ '404.title' | t }}</h1>
    <p class="text-muted-foreground font-light mb-10">{{ '404.description' | t }}</p>
    <a href="/" class="inline-flex items-center justify-center h-14 px-10 bg-foreground text-background text-xs font-medium uppercase tracking-[0.15em] hover:bg-foreground/90 transition-colors">
      {{ '404.button' | t }}
    </a>
  </div>
</section>

{% schema %}
{
  "name": "404 Content",
  "settings": []
}
{% endschema %}
