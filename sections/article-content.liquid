{%- comment -%}
  Article Content — Full article body with Chart.js support
{%- endcomment -%}

<article class="py-12 md:py-20">
  <div class="container max-w-3xl mx-auto">
    {%- comment -%} Article Header {%- endcomment -%}
    <header class="mb-12">
      {%- if article.tags.size > 0 -%}
        <div class="flex items-center gap-3 mb-4">
          {%- for tag in article.tags -%}
            <span class="text-[10px] tracking-[0.15em] uppercase text-muted-foreground font-light">{{ tag }}</span>
          {%- endfor -%}
        </div>
      {%- endif -%}

      <h1 class="font-serif text-3xl md:text-4xl lg:text-5xl font-light leading-tight tracking-tight mb-6">
        {{ article.title }}
      </h1>

      <div class="flex items-center gap-4 text-sm text-muted-foreground">
        <time datetime="{{ article.published_at | date: '%Y-%m-%d' }}">
          {{ article.published_at | date: '%B %d, %Y' }}
        </time>
        {%- if article.metafields.custom.read_time -%}
          <span>&middot;</span>
          <span>{{ article.metafields.custom.read_time }} min read</span>
        {%- endif -%}
      </div>
    </header>

    {%- comment -%} Featured Image {%- endcomment -%}
    {%- if article.image -%}
      <div class="aspect-[16/9] overflow-hidden mb-12">
        <img
          src="{{ article.image | image_url: width: 1400 }}"
          alt="{{ article.image.alt | default: article.title }}"
          class="w-full h-full object-cover"
          loading="eager"
        >
      </div>
    {%- endif -%}

    {%- comment -%} Article Body {%- endcomment -%}
    <div class="prose prose-lg max-w-none
      prose-headings:font-display prose-headings:tracking-tight prose-headings:font-light
      prose-h2:text-2xl prose-h2:mt-12 prose-h2:mb-4
      prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-3
      prose-p:text-foreground/80 prose-p:font-light prose-p:leading-relaxed
      prose-a:text-foreground prose-a:underline prose-a:underline-offset-4 prose-a:hover:opacity-60
      prose-strong:font-medium
      prose-img:rounded-none
      prose-blockquote:border-l-foreground prose-blockquote:font-serif prose-blockquote:italic
      ">
      {{ article.content }}
    </div>

    {%- comment -%} Chart.js Container — renders if article has chart metafields {%- endcomment -%}
    {%- if article.metafields.custom.chart_data -%}
      <div class="my-12 p-6 bg-[hsl(var(--diagram))]">
        <canvas
          data-chart="{{ article.metafields.custom.chart_data | escape }}"
          data-chart-type="{{ article.metafields.custom.chart_type | default: 'bar' }}"
          class="w-full"
          style="max-height: 400px;"
        ></canvas>
      </div>
      <script src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js" defer></script>
      <script src="{{ 'chart-init.js' | asset_url }}" defer></script>
    {%- endif -%}

    {%- comment -%} Back to Editorial {%- endcomment -%}
    <div class="mt-16 pt-8 border-t border-border">
      <a href="{{ blog.url }}" class="text-sm font-medium underline underline-offset-4 hover:opacity-60 transition-opacity">
        &larr; Back to Editorial
      </a>
    </div>
  </div>
</article>

{% schema %}
{
  "name": "Article Content",
  "settings": []
}
{% endschema %}
