{%- comment -%}
  Article Content — Full article body with Chart.js support
{%- endcomment -%}

<article class="py-16 md:py-24">
  <div class="container max-w-5xl mx-auto">
    {%- comment -%} Article Header {%- endcomment -%}
    <header class="mb-12">
      {%- comment -%} Metadata line: Tag • Month Year • X min read {%- endcomment -%}
      {%- assign word_count = article.content | strip_html | split: ' ' | size -%}
      {%- assign read_time = word_count | divided_by: 230 -%}
      {%- if read_time == 0 -%}{%- assign read_time = 1 -%}{%- endif -%}

      <div class="flex flex-wrap items-center gap-2 mb-6 text-[11px] tracking-[0.12em] uppercase text-muted-foreground font-light">
        {%- for tag in article.tags -%}
          <span>{{ tag }}</span>
          <span class="text-muted-foreground/40">&bull;</span>
        {%- endfor -%}
        <time datetime="{{ article.published_at | date: '%Y-%m-%d' }}">
          {{ article.published_at | date: '%B %Y' }}
        </time>
        <span class="text-muted-foreground/40">&bull;</span>
        <span>{{ read_time }} min read</span>
      </div>

      <h1 class="font-serif text-3xl md:text-5xl leading-tight tracking-tight mb-8">
        {{ article.title }}
      </h1>
    </header>

    {%- comment -%} Lead Paragraph / Excerpt {%- endcomment -%}
    {%- if article.excerpt != blank -%}
      <p class="text-lg md:text-xl text-muted-foreground leading-relaxed mb-12">
        {{ article.excerpt | strip_html }}
      </p>
    {%- endif -%}

    {%- comment -%} Featured Image {%- endcomment -%}
    {%- if article.image -%}
      <div class="aspect-[21/9] bg-muted overflow-hidden mb-12">
        <img
          src="{{ article.image | image_url: width: 1400 }}"
          alt="{{ article.image.alt | default: article.title }}"
          class="w-full h-full object-cover"
          loading="eager"
        >
      </div>
    {%- endif -%}

    {%- comment -%} Article Body {%- endcomment -%}
    <div class="article-body space-y-12">
      {{ article.content }}
    </div>

    {%- comment -%} Chart.js Container — renders if article has chart metafields {%- endcomment -%}
    {%- if article.metafields.custom.chart_data -%}
      <div class="my-12 p-6 bg-[hsl(var(--diagram))]">
        <canvas
          data-chart="{{ article.metafields.custom.chart_data | escape }}"
          data-chart-type="{{ article.metafields.custom.chart_type | default: 'bar' }}"
          class="w-full"
          style="max-height: 400px;"
        ></canvas>
      </div>
      <script src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js" defer></script>
      <script src="{{ 'chart-init.js' | asset_url }}" defer></script>
    {%- endif -%}

    {%- comment -%} Back to Editorial {%- endcomment -%}
    <div class="mt-16 pt-8 border-t border-border">
      <a href="{{ blog.url }}" class="text-sm font-medium underline underline-offset-4 hover:opacity-60 transition-opacity">
        &larr; Back to Editorial
      </a>
    </div>
  </div>
</article>

{% schema %}
{
  "name": "Article Content",
  "settings": []
}
{% endschema %}
