{%- comment -%}
  Product Ingredients — Fullscreen section with hover crossfade (desktop) and accordion (mobile)
  Used on individual product pages
{%- endcomment -%}

{%- if section.blocks.size > 0 -%}
<section class="relative md:min-h-[80vh] bg-[#3d3530]" data-ingredient-section>
  {%- comment -%} Background images {%- endcomment -%}
  {%- for block in section.blocks -%}
    {%- if block.settings.image -%}
      <div class="ingredient-bg {% if forloop.first %}is-active{% endif %}" data-ingredient-bg="{{ forloop.index0 }}">
        <img src="{{ block.settings.image | image_url: width: 1600 }}" alt="{{ block.settings.name }}" class="w-full h-full object-cover" loading="lazy">
      </div>
    {%- endif -%}
  {%- endfor -%}
  <div class="absolute inset-0 bg-black/40"></div>

  {%- comment -%} Desktop {%- endcomment -%}
  <div class="hidden md:block relative z-10 min-h-[80vh]">
    <div class="absolute top-12 left-12 right-12">
      <p class="text-[10px] uppercase tracking-[0.3em] text-white/80 font-light mb-4">{{ section.settings.heading | default: 'Key Ingredients' }}</p>
      <div class="border-t border-white/30"></div>
    </div>
    <div class="absolute top-32 left-12 space-y-4">
      {%- for block in section.blocks -%}
        <div data-ingredient-trigger="{{ forloop.index0 }}" class="flex items-baseline gap-5 cursor-pointer transition-opacity duration-300" {{ block.shopify_attributes }}>
          <span class="text-white/60 text-sm font-light">0{{ forloop.index }}</span>
          <span class="text-white text-[36px] font-light">{{ block.settings.name }}</span>
          <span class="text-[10px] uppercase tracking-[0.15em] text-white/70 font-light">{{ block.settings.benefit }}</span>
        </div>
      {%- endfor -%}
    </div>
    <div class="absolute bottom-12 right-12 max-w-md text-right">
      <p class="text-white/90 text-lg font-light leading-relaxed">{{ section.settings.description }}</p>
    </div>
  </div>

  {%- comment -%} Mobile {%- endcomment -%}
  <div class="md:hidden relative z-10 px-6 py-12">
    <p class="text-[10px] uppercase tracking-[0.3em] text-white/80 font-light mb-3">{{ section.settings.heading | default: 'Key Ingredients' }}</p>
    <p class="text-white/90 text-base font-light mb-10">{{ section.settings.description }}</p>
    <div class="accordion-group">
      {%- for block in section.blocks -%}
        <div class="accordion-item border-t border-white/30" {{ block.shopify_attributes }}>
          <button class="accordion-trigger w-full py-5 flex items-center justify-between">
            <div class="flex items-baseline gap-3">
              <span class="text-white/60 text-sm font-light">0{{ forloop.index }}</span>
              <span class="text-white text-xl font-light">{{ block.settings.name }}</span>
              <span class="text-[9px] uppercase tracking-[0.1em] text-white/70 font-light">{{ block.settings.benefit }}</span>
            </div>
            <span class="accordion-icon text-white/70 text-lg">+</span>
          </button>
          <div class="accordion-content">
            <p class="text-white/80 text-sm font-light pb-4">{{ block.settings.description }}</p>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>
{%- endif -%}

{% schema %}
{
  "name": "Product Ingredients",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Key Ingredients" },
    { "type": "textarea", "id": "description", "label": "Description", "default": "Each ingredient is selected for its proven ability to create a lasting moisture barrier." }
  ],
  "blocks": [
    {
      "type": "ingredient",
      "name": "Ingredient",
      "settings": [
        { "type": "text", "id": "name", "label": "Name" },
        { "type": "text", "id": "benefit", "label": "Benefit" },
        { "type": "textarea", "id": "description", "label": "Description" },
        { "type": "image_picker", "id": "image", "label": "Background Image" }
      ]
    }
  ],
  "presets": [{ "name": "Product Ingredients" }]
}
{% endschema %}
