{%- comment -%}
  Main Cart — Fallback cart page (if JS cart drawer fails)
{%- endcomment -%}

<section class="py-16 md:py-24">
  <div class="container max-w-3xl mx-auto">
    <h1 class="text-3xl font-light tracking-tight mb-8">{{ 'cart.title' | t }}</h1>

    {%- if cart.item_count > 0 -%}
      <form action="/cart" method="post">
        {%- for item in cart.items -%}
          <div class="flex gap-4 p-4 border-b border-border">
            <a href="{{ item.url }}" class="shrink-0 w-20 h-20 bg-muted overflow-hidden">
              {%- if item.image -%}
                <img src="{{ item.image | image_url: width: 200 }}" alt="{{ item.title }}" class="w-full h-full object-cover">
              {%- endif -%}
            </a>
            <div class="flex-1">
              <a href="{{ item.url }}" class="text-sm font-medium">{{ item.product.title }}</a>
              {%- if item.variant.title != 'Default Title' -%}
                <p class="text-xs text-muted-foreground">{{ item.variant.title }}</p>
              {%- endif -%}
              <p class="text-sm font-light mt-1">{{ item.final_line_price | money }}</p>
              <div class="flex items-center gap-2 mt-2">
                <label for="qty-{{ item.key }}" class="sr-only">Quantity</label>
                <input type="number" id="qty-{{ item.key }}" name="updates[{{ item.key }}]" value="{{ item.quantity }}" min="0" class="w-16 h-8 text-center border border-border text-sm bg-transparent">
              </div>
            </div>
          </div>
        {%- endfor -%}

        <div class="mt-8 flex items-center justify-between">
          <div>
            <span class="text-sm font-medium uppercase tracking-wide">{{ 'cart.subtotal' | t }}</span>
            <span class="text-lg font-light ml-4">{{ cart.total_price | money }}</span>
          </div>
          <div class="flex gap-3">
            <button type="submit" name="update" class="px-6 h-12 border border-foreground text-xs uppercase tracking-[0.15em] font-medium hover:bg-muted transition-colors">
              Update
            </button>
            <button type="submit" name="checkout" class="px-6 h-12 bg-foreground text-background text-xs uppercase tracking-[0.15em] font-medium hover:bg-foreground/90 transition-colors">
              {{ 'cart.checkout' | t }}
            </button>
          </div>
        </div>
      </form>
    {%- else -%}
      <div class="text-center py-16">
        <p class="text-muted-foreground mb-6">{{ 'cart.empty' | t }}</p>
        <a href="/collections/all" class="inline-flex items-center justify-center h-14 px-10 bg-foreground text-background text-xs font-medium uppercase tracking-[0.15em] hover:bg-foreground/90 transition-colors">
          {{ 'general.continue_shopping' | t }}
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Cart Page",
  "settings": []
}
{% endschema %}
