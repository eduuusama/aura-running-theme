{%- comment -%}
  Product FAQ — Accordion section matching React ProductAccordionItem
{%- endcomment -%}

<section class="py-20 md:py-28 bg-background">
  <div class="container max-w-4xl">
    <p class="text-[10px] uppercase tracking-[0.2em] text-muted-foreground mb-6 font-medium">
      {{ section.settings.label | default: 'Questions' }}
    </p>
    <h2 class="font-light text-[28px] md:text-[36px] tracking-[-0.02em] leading-[1.2] mb-12">
      {{ section.settings.heading | default: 'Frequently Asked' }}
    </h2>

    <div class="accordion-group">
      {%- for block in section.blocks -%}
        <div class="accordion-item border-t border-border {% if forloop.last %}border-b{% endif %}" {{ block.shopify_attributes }}>
          <button class="accordion-trigger w-full py-6 flex items-center justify-between text-base font-light hover:opacity-70 transition-opacity text-left">
            <span>{{ block.settings.title }}</span>
            <span class="accordion-icon text-base shrink-0 ml-4">+</span>
          </button>
          <div class="accordion-content">
            <p class="text-base text-muted-foreground font-light leading-[1.6] pb-8">
              {{ block.settings.answer }}
            </p>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product FAQ",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "label", "label": "Label", "default": "Questions" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Frequently Asked" }
  ],
  "blocks": [
    {
      "type": "question",
      "name": "Question",
      "settings": [
        { "type": "text", "id": "title", "label": "Question" },
        { "type": "textarea", "id": "answer", "label": "Answer" }
      ]
    }
  ],
  "presets": [{ "name": "Product FAQ" }]
}
{% endschema %}
