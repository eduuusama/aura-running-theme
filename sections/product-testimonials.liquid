{%- comment -%}
  Product Testimonials — Customer quote cards
{%- endcomment -%}

{%- if section.blocks.size > 0 -%}
<section class="py-20 md:py-28 bg-secondary">
  <div class="container">
    <p class="text-xs tracking-[0.2em] uppercase text-muted-foreground mb-12 font-light">
      {{ section.settings.heading | default: 'What Runners Say' }}
    </p>
    <div class="grid grid-cols-1 md:grid-cols-{{ section.blocks.size | at_most: 3 }} gap-8">
      {%- for block in section.blocks -%}
        <blockquote class="bg-background p-8" {{ block.shopify_attributes }}>
          <p class="font-serif text-lg italic font-light leading-relaxed mb-6">
            "{{ block.settings.quote }}"
          </p>
          <footer>
            <cite class="not-italic">
              <span class="block text-sm font-medium">{{ block.settings.author }}</span>
              <span class="block text-xs text-muted-foreground mt-1">{{ block.settings.attribution }}</span>
            </cite>
          </footer>
        </blockquote>
      {%- endfor -%}
    </div>
  </div>
</section>
{%- endif -%}

{% schema %}
{
  "name": "Product Testimonials",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "What Runners Say" }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        { "type": "textarea", "id": "quote", "label": "Quote" },
        { "type": "text", "id": "author", "label": "Author" },
        { "type": "text", "id": "attribution", "label": "Attribution" }
      ]
    }
  ],
  "presets": [{ "name": "Product Testimonials" }]
}
{% endschema %}
