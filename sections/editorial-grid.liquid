{%- comment -%}
  Editorial Grid — 3-column article cards from a Shopify blog
{%- endcomment -%}

{%- assign blog_handle = section.settings.blog | default: 'editorial' -%}
{%- assign article_count = section.settings.article_count | default: 3 -%}

<section class="py-20 md:py-28 bg-secondary">
  <div class="container">
    <p class="text-xs tracking-[0.2em] uppercase text-muted-foreground mb-12 font-light">
      {{ section.settings.heading | default: 'From the Editorial' }}
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
      {%- for article in blogs[blog_handle].articles limit: article_count -%}
        <article class="group">
          {%- comment -%} Image {%- endcomment -%}
          <a href="{{ article.url }}" class="block aspect-[4/3] bg-muted mb-6 overflow-hidden">
            {%- if article.image -%}
              <img
                src="{{ article.image | image_url: width: 800 }}"
                alt="{{ article.image.alt | default: article.title }}"
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
              >
            {%- else -%}
              <div class="w-full h-full flex items-center justify-center text-muted-foreground">
                <span class="text-xs uppercase tracking-widest">Image Coming Soon</span>
              </div>
            {%- endif -%}
          </a>

          {%- comment -%} Category Tag {%- endcomment -%}
          {%- if article.tags.size > 0 -%}
            <div class="flex items-center gap-3 mb-3">
              <span class="text-[10px] tracking-[0.15em] uppercase text-muted-foreground font-light">
                {{ article.tags.first }}
              </span>
            </div>
          {%- endif -%}

          {%- comment -%} Title {%- endcomment -%}
          <a href="{{ article.url }}">
            <h3 class="font-serif text-lg mb-3 group-hover:opacity-60 transition-opacity line-clamp-2">
              {{ article.title }}
            </h3>
          </a>

          {%- comment -%} Discover Link {%- endcomment -%}
          <a
            href="{{ article.url }}"
            class="inline-block text-sm font-medium underline underline-offset-4 hover:opacity-60 transition-opacity"
          >
            {{ 'general.discover' | t }}
          </a>
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Editorial Grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "From the Editorial"
    },
    {
      "type": "blog",
      "id": "blog",
      "label": "Blog"
    },
    {
      "type": "range",
      "id": "article_count",
      "label": "Number of Articles",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 3
    }
  ],
  "presets": [
    {
      "name": "Editorial Grid"
    }
  ]
}
{% endschema %}
