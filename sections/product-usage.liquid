{%- comment -%}
  Product Usage — "How to Use" section
  50/50 split: product image left (sticky), usage info right
{%- endcomment -%}

{%- comment -%} Desktop Layout — 50/50 Split {%- endcomment -%}
<div class="hidden lg:block">
  <div class="grid grid-cols-2">
    {%- comment -%} Left — Sticky product image {%- endcomment -%}
    <div class="bg-[hsl(var(--secondary))] relative">
      <div class="sticky top-16 h-[calc(100vh-64px)] flex items-center justify-center overflow-hidden">
        {%- if section.settings.image -%}
          <img
            src="{{ section.settings.image | image_url: width: 1400 }}"
            alt="{{ product.title }}"
            class="w-full h-full object-cover"
            loading="lazy"
          >
        {%- else -%}
          <img
            src="{{ product.featured_image | image_url: width: 1400 }}"
            alt="{{ product.title }}"
            class="w-full h-full object-cover"
            loading="lazy"
          >
        {%- endif -%}
      </div>
    </div>

    {%- comment -%} Right — Usage info {%- endcomment -%}
    <div class="px-16 lg:px-24 xl:px-32 py-24">
      <div class="max-w-lg">
        <p class="text-[10px] uppercase tracking-[0.2em] text-muted-foreground mb-6 font-medium">
          {{ section.settings.label | default: 'How to Use' }}
        </p>
        <h2 class="font-light text-[28px] md:text-[32px] lg:text-[36px] tracking-[-0.02em] leading-[1.2] mb-12">
          {{ section.settings.heading | default: 'When to Use' }}
        </h2>
        <p class="text-base text-muted-foreground font-light leading-[1.6] mb-12">
          {{ section.settings.description }}
        </p>

        {%- for block in section.blocks -%}
          <div class="border-t border-border pt-8 {% unless forloop.last %}mb-8{% else %}mb-0{% endunless %}" {{ block.shopify_attributes }}>
            <p class="text-sm font-medium mb-2">{{ block.settings.name }}</p>
            <p class="text-base text-muted-foreground font-light leading-[1.6]">{{ block.settings.text }}</p>
          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>
</div>

{%- comment -%} Mobile Layout {%- endcomment -%}
<div class="lg:hidden">
  {%- if section.settings.image -%}
    <div class="bg-[hsl(var(--secondary))]">
      <img
        src="{{ section.settings.image | image_url: width: 1200 }}"
        alt="{{ product.title }}"
        class="w-full aspect-square object-cover"
        loading="lazy"
      >
    </div>
  {%- endif -%}

  <div class="px-6 md:px-12 py-12 md:py-16 md:max-w-2xl md:mx-auto">
    <p class="text-[10px] uppercase tracking-[0.2em] text-muted-foreground mb-4 font-medium">
      {{ section.settings.label | default: 'How to Use' }}
    </p>
    <h2 class="font-light text-[24px] md:text-[28px] tracking-[-0.02em] leading-[1.2] mb-8">
      {{ section.settings.heading | default: 'When to Use' }}
    </h2>
    <p class="text-base text-muted-foreground font-light leading-[1.6] mb-8">
      {{ section.settings.description }}
    </p>

    {%- for block in section.blocks -%}
      <div class="border-t border-border pt-6 {% unless forloop.last %}mb-6{% else %}mb-0{% endunless %}" {{ block.shopify_attributes }}>
        <p class="text-sm font-medium mb-2">{{ block.settings.name }}</p>
        <p class="text-base text-muted-foreground font-light leading-[1.6]">{{ block.settings.text }}</p>
      </div>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Product Usage",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "label", "label": "Label", "default": "HOW TO USE" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "When to Use" },
    { "type": "textarea", "id": "description", "label": "Description" },
    { "type": "image_picker", "id": "image", "label": "Product Image", "info": "Optional. Falls back to product featured image." }
  ],
  "blocks": [
    {
      "type": "detail",
      "name": "Detail",
      "settings": [
        { "type": "text", "id": "name", "label": "Name", "default": "Dosage" },
        { "type": "textarea", "id": "text", "label": "Text" }
      ]
    }
  ],
  "presets": [{ "name": "Product Usage" }]
}
{% endschema %}
