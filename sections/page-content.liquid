{%- comment -%}
  Page Content — Generic rich text page (policies, terms, etc.)
{%- endcomment -%}

<section class="py-16 md:py-24">
  <div class="container max-w-3xl mx-auto">
    <h1 class="text-3xl md:text-4xl font-light tracking-tight mb-8">{{ page.title }}</h1>
    <div class="prose prose-lg max-w-none
      prose-headings:font-display prose-headings:tracking-tight prose-headings:font-light
      prose-h2:text-xl prose-h2:mt-10 prose-h2:mb-4
      prose-h3:text-lg prose-h3:mt-6 prose-h3:mb-3
      prose-p:text-foreground/80 prose-p:font-light prose-p:leading-relaxed prose-p:text-sm
      prose-li:text-foreground/80 prose-li:font-light prose-li:text-sm
      prose-a:text-foreground prose-a:underline prose-a:underline-offset-4
      prose-strong:font-medium
    ">
      {{ page.content }}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Page Content",
  "settings": []
}
{% endschema %}
