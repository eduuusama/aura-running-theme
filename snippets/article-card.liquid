{%- comment -%}
  Article Card — Reusable blog article card snippet
  Usage: {% render 'article-card', article: article %}
{%- endcomment -%}

<article class="group">
  <a href="{{ article.url }}" class="block aspect-[4/3] bg-muted mb-6 overflow-hidden">
    {%- if article.image -%}
      <img
        src="{{ article.image | image_url: width: 800 }}"
        alt="{{ article.image.alt | default: article.title }}"
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
        loading="lazy"
      >
    {%- else -%}
      <div class="w-full h-full flex items-center justify-center text-muted-foreground">
        <span class="text-xs uppercase tracking-widest">Image Coming Soon</span>
      </div>
    {%- endif -%}
  </a>

  {%- if article.tags.size > 0 -%}
    <div class="flex items-center gap-3 mb-3">
      <span class="text-[10px] tracking-[0.15em] uppercase text-muted-foreground font-light">
        {{ article.tags.first }}
      </span>
    </div>
  {%- endif -%}

  <a href="{{ article.url }}">
    <h3 class="font-serif text-lg mb-3 group-hover:opacity-60 transition-opacity line-clamp-2">
      {{ article.title }}
    </h3>
  </a>

  <a href="{{ article.url }}" class="inline-block text-sm font-medium underline underline-offset-4 hover:opacity-60 transition-opacity">
    Discover
  </a>
</article>
